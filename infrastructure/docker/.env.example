# Ejemplo de archivo .env para TechNovaStore (NO usar en producción)
# Rellena estos valores con los datos reales en tu entorno local

# Variables para autenticación AppRole de Vault
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=pon_aqui_tu_role_id
VAULT_SECRET_ID=pon_aqui_tu_secret_id

# Credenciales iniciales para PostgreSQL (solo para arranque, acceso real vía Vault)
POSTGRES_USER=pon_aqui_usuario
POSTGRES_PASSWORD=pon_aqui_password
POSTGRES_DB=pon_aqui_nombre_db
